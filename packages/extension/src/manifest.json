{
  "manifest_version": 3,
  "name": "Merx",
  "version": "0.1.0",
  "description": "Find cheaper alternatives for any product you see online.",
  "permissions": ["sidePanel", "storage", "activeTab", "scripting"],
  "host_permissions": ["http://localhost:8080/*", "https://*.run.app/*"],
  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/index.ts"],
      "run_at": "document_idle"
    }
  ],
  "side_panel": {
    "default_path": "src/sidepanel/index.html"
  },
  "action": {
    "default_title": "Merx"
  },
  "web_accessible_resources": [
    {
      "resources": ["src/sidepanel/audio-worklet-processor.js"],
      "matches": ["<all_urls>"]
    },
    {
      "resources": ["src/mic-permission/index.html"],
      "matches": ["<all_urls>"]
    }
  ],
  "icons": {
    "16": "src/icons/icon-16.png",
    "32": "src/icons/icon-32.png",
    "48": "src/icons/icon-48.png",
    "128": "src/icons/icon-128.png"
  }
}
