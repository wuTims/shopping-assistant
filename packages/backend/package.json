{
  "name": "@shopping-assistant/backend",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "build": "tsup",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@google/genai": "^1.0.0",
    "@hono/node-server": "^1.0.0",
    "@hono/node-ws": "^1.0.0",
    "@shopping-assistant/shared": "workspace:*",
    "hono": "^4.0.0",
    "playwright": "^1.58.2",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/sharp": "^0.32.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  }
}
